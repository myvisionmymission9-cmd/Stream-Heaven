# Server
PORT=3001
NODE_ENV=development

# PostgreSQL (auth-service dedicated DB)
DATABASE_URL=postgresql://sh_auth:sh_auth_dev@localhost:5432/sh_auth

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate strong secrets for non-dev)
JWT_ACCESS_SECRET=dev-access-secret-change-in-prod-min-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-prod-min-32-chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Firebase Admin (optional in dev — mock verifier used when unset)
FIREBASE_PROJECT_ID=stream-heaven-ad95a
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# OTP
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_PER_HOUR=5

# Phone encryption (32-byte hex for AES-256-GCM)
PHONE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Mock SMS — logs OTP to console in dev
SMS_PROVIDER=mock
