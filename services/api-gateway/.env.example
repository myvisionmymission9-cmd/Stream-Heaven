PORT=3000
NODE_ENV=development

# JWT validation (must match auth-service)
JWT_ACCESS_SECRET=dev-access-secret-change-in-prod-min-32-chars

# Upstream services
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
SOCIAL_SERVICE_URL=http://localhost:3003
LIVESTREAM_SERVICE_URL=http://localhost:3004
REALTIME_GATEWAY_URL=http://localhost:3009

# Redis (rate limiting)
REDIS_URL=redis://localhost:6379

# CORS — comma-separated origins for mobile/web dev
CORS_ORIGINS=http://localhost:*,capacitor://localhost

# Rate limits (requests per minute)
RATE_LIMIT_ANONYMOUS=30
RATE_LIMIT_AUTHENTICATED=300
